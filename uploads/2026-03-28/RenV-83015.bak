            </div>

            <div class="contact-grid">
              <a class="contact-card" href="https://wa.me/6285702107250?text=Halo%20Panpan%2C%20saya%20ingin%20kontak%20kamu." target="_blank">
                <span class="contact-label">[ whatsapp ]</span>
