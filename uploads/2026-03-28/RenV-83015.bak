            <div class="tech-stack">
              <span>Baileys</span>
              <span>Node.js</span>
              <span>AI/ML</span>
              <span>Socket.io</span>
            </div>

            <div class="project-actions">
              <a class="btn btn-green" href="https://wa.me/6285702107250?text=Halo%20Panpan%2C%20saya%20mau%20kontak%20Renvy%20WhatsApp%20Bot." target="_blank">Contact Bot (6285702107250)</a>
            </div>
          </div>

          <div class="project neo assemble assemble-right" data-delay="2">
