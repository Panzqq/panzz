              </a>

              <div class="contact-card contact-status-card">
                <span class="contact-label">{ status }</span>
                <strong>Available for Projects</strong>
                <small><span class="status-ping"></span>open for collaboration</small>
              </div>

              <div class="contact-map-card">
                <div class="contact-map-head">
                  <span class="contact-label">[ live_map ]</span>
                  <a href="https://www.google.com/maps/search/?api=1&query=Sanden+Bantul+Yogyakarta" target="_blank">open maps</a>
                </div>
                <div class="contact-map-frame">
                  <iframe
                    title="Map of Sanden Bantul Yogyakarta"
                    src="https://maps.google.com/maps?q=Sanden%20Bantul%20Yogyakarta&t=&z=12&ie=UTF8&iwloc=&output=embed"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
                <div class="contact-map-caption">
                  <strong>Yogyakarta, Bantul, Sanden</strong>
                  <small>current base location</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer style="padding:26px 0 42px;">
    <div class="container">
      <div class="footer-box neo">
        <span>© 2026 Panpan — Bots, APIs, and Web Interfaces</span>
        <span class="mono">Built for automation, API tools, and modern web products</span>
      </div>
    </div>
  </footer>

  <a class="wa-float" href="https://wa.me/6285702107250?text=Halo%20Panpan%2C%20saya%20ingin%20kontak%20kamu." target="_blank" aria-label="Chat WhatsApp">
    ⌁
  </a>

  <script>
    const preloader = document.getElementById('preloader');
    let preloaderClosed = false;

    function finishPreloader(){
      if (preloaderClosed) return;
      preloaderClosed = true;
      preloader?.classList.add('hide');
      setTimeout(() => loadTrack(0, true), 180);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(finishPreloader, 4000);
      }, { once: true });
    } else {
      setTimeout(finishPreloader, 4000);
    }


    
    const TRACKS = [
      {
        title: 'Love Me Not',
        file: 'RenV-45332.mpeg',
        url: 'https://raw.githubusercontent.com/Panzqq/panzz/main/uploads/2026-03-25/RenV-45332.mpeg'
      },
      {
        title: 'One Last Time',
        file: 'RenV-39478.mpeg',
        url: 'https://raw.githubusercontent.com/Panzqq/panzz/main/uploads/2026-03-25/RenV-39478.mpeg'
      },
      {
        title: 'Impossible',
        file: 'RenV-82306.mpeg',
        url: 'https://raw.githubusercontent.com/Panzqq/panzz/main/uploads/2026-03-25/RenV-82306.mpeg'
      }
    ];

    const bgMusic = document.getElementById('bgMusic');
    const playMusicBtn = document.getElementById('playMusicBtn');
    const pauseMusicBtn = document.getElementById('pauseMusicBtn');
    const nextTrackBtn = document.getElementById('nextTrackBtn');
    const musicCurrentTime = document.getElementById('musicCurrentTime');
    const musicDuration = document.getElementById('musicDuration');
    const musicProgress = document.getElementById('musicProgress');
    const musicProgressBar = document.getElementById('musicProgressBar');
    const playlistNext = document.getElementById('playlistNext');
    const musicStatusChip = document.getElementById('musicStatusChip');
    const currentTrackChip = document.getElementById('currentTrackChip');
    const musicConsole = document.querySelector('.music-console');
    const musicTrackRail = document.getElementById('musicTrackRail');
    const trackCards = Array.from(document.querySelectorAll('.track-card'));
    let currentTrackIndex = 0;

    function setMusicState(stateText, cssState = ''){
      if (musicStatusChip) musicStatusChip.textContent = 'status: ' + stateText;
      if (musicConsole) {
        musicConsole.classList.remove('paused', 'stopped');
        if (cssState) musicConsole.classList.add(cssState);
      }
    }


    function formatTime(sec){
      if (!isFinite(sec) || sec < 0) return '0:00';
      const minutes = Math.floor(sec / 60);
      const seconds = Math.floor(sec % 60);
      return minutes + ':' + String(seconds).padStart(2, '0');
    }

    function updateProgress(){
      if (!bgMusic) return;
      const current = bgMusic.currentTime || 0;
      const duration = bgMusic.duration || 0;
      if (musicCurrentTime) musicCurrentTime.textContent = formatTime(current);
      if (musicDuration) musicDuration.textContent = formatTime(duration);
      const progress = duration > 0 ? (current / duration) * 100 : 0;
      if (musicProgressBar) musicProgressBar.style.width = progress + '%';
    }

    function updateTrackUI(index){
      currentTrackIndex = index;
      const track = TRACKS[index];
      if (currentTrackChip) currentTrackChip.textContent = 'track: ' + track.title;
      trackCards.forEach((card, i) => {
        card.classList.toggle('active', i === index);
      });
    }

    function loadTrack(index, shouldAutoplay = false){
      const safeIndex = (index + TRACKS.length) % TRACKS.length;
      const wasPlaying = bgMusic && !bgMusic.paused && bgMusic.currentTime > 0;
      updateTrackUI(safeIndex);
      if (bgMusic) {
        bgMusic.src = TRACKS[safeIndex].url;
        bgMusic.load();
      }
      if (musicCurrentTime) musicCurrentTime.textContent = '0:00';
      if (musicDuration) musicDuration.textContent = '0:00';
      if (musicProgressBar) musicProgressBar.style.width = '0%';
      if (shouldAutoplay || wasPlaying) {
        playMusic();
      } else {
        setMusicState('ready', 'paused');
      }
    }

    async function playMusic(){
      if (!bgMusic) return;
      try {
        await bgMusic.play();
        setMusicState('playing');
      } catch (e) {
        setMusicState('autoplay blocked — tap anywhere', 'paused');
        bindMusicUnlock();
      }
    }


    let musicUnlockBound = false;

    function bindMusicUnlock(){
      if (musicUnlockBound) return;
      musicUnlockBound = true;
      const unlock = async () => {
        try {
          await playMusic();
        } finally {
          document.removeEventListener('pointerdown', unlock);
          document.removeEventListener('touchstart', unlock);
          document.removeEventListener('click', unlock);
        }
      };
      document.addEventListener('pointerdown', unlock, { once: true, passive: true });
      document.addEventListener('touchstart', unlock, { once: true, passive: true });
      document.addEventListener('click', unlock, { once: true, passive: true });
    }

    function pauseMusic(){
      if (!bgMusic) return;
      bgMusic.pause();
      setMusicState('paused', 'paused');
    }

    function stopMusic(){
      if (!bgMusic) return;
      bgMusic.pause();
      bgMusic.currentTime = 0;
      setMusicState('stopped', 'stopped');
    }

    function nextTrack(autoplay = true){
      loadTrack(currentTrackIndex + 1, autoplay);
    }

    function prevTrack(autoplay = true){
      loadTrack(currentTrackIndex - 1, autoplay);
    }

    playMusicBtn?.addEventListener('click', playMusic);
    pauseMusicBtn?.addEventListener('click', pauseMusic);
    nextTrackBtn?.addEventListener('click', () => nextTrack(true));
    playlistNext?.addEventListener('click', () => {
      musicTrackRail?.scrollBy({ left: 240, behavior: 'smooth' });
      nextTrack(false);
    });

    trackCards.forEach((card) => {
      card.addEventListener('click', () => {
        const index = parseInt(card.dataset.trackIndex || '0', 10);
        loadTrack(index, true);
      });
    });

    bgMusic?.addEventListener('play', () => setMusicState('playing'));
    bgMusic?.addEventListener('pause', () => {
      if (bgMusic.currentTime > 0 && !bgMusic.ended) setMusicState('paused', 'paused');
    });

    bgMusic?.addEventListener('loadedmetadata', updateProgress);
    bgMusic?.addEventListener('timeupdate', updateProgress);
    bgMusic?.addEventListener('ended', updateProgress);

    musicProgress?.addEventListener('click', (e) => {
      if (!bgMusic || !bgMusic.duration) return;
      const rect = musicProgress.getBoundingClientRect();
      const ratio = Math.min(Math.max((e.clientX - rect.left) / rect.width, 0), 1);
      bgMusic.currentTime = ratio * bgMusic.duration;
      updateProgress();
    });


    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible' && bgMusic && bgMusic.paused) {
        playMusic();
      }
    });

    loadTrack(0, false);

    const menuBtn = document.getElementById('menuBtn');
    const navLinks = document.getElementById('navLinks');

    function toggleMenu(force){
      const open = force !== undefined ? force : !navLinks.classList.contains('open');
      navLinks.classList.toggle('open', open);
      menuBtn.classList.toggle('active', open);
    }

    menuBtn?.addEventListener('click', () => toggleMenu());
    document.querySelectorAll('.nav-links a').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 780) toggleMenu(false);
      });
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth > 780) {
        navLinks.classList.remove('open');
        menuBtn.classList.remove('active');
      }
    });

    const assembleObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('show');
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.assemble').forEach(el => {
      if (!el.classList.contains('show')) assembleObserver.observe(el);
    });

    const quote = "Kamu tidak akan menemukan seseorang yang sama untuk kedua kalinya, bahkan tidak dalam diri orang itu sendiri, setelah waktu dan keadaan mengubahnya.";
    const typedText = document.getElementById('typedText');
    const terminalBox = document.querySelector('.terminal-box');

    function escapeChar(ch){
      return ch === ' ' ? '&nbsp;' : ch
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function typeLoop(index = 0){
      if (!typedText) return;
      if (index === 0) {
        typedText.classList.remove('shattering');
        typedText.textContent = '';
      }
      if (index < quote.length) {
        typedText.textContent += quote.charAt(index);
        setTimeout(() => typeLoop(index + 1), 28);
      } else {
        setTimeout(shatterText, 3000);
      }
    }

    function shatterText(){
      if (!typedText) return;
      const chars = Array.from(quote).map((ch, i) => {
        const tx = (Math.random() * 90 - 45).toFixed(1) + 'px';
        const ty = (Math.random() * -70 - 8).toFixed(1) + 'px';
        const tr = (Math.random() * 80 - 40).toFixed(1) + 'deg';
        return `<span class="shard" style="--i:${i};--tx:${tx};--ty:${ty};--tr:${tr}">${escapeChar(ch)}</span>`;
      }).join('');
      typedText.innerHTML = chars;
      typedText.classList.add('shattering');
      terminalBox?.classList.add('crack');

      setTimeout(() => {
        typedText.classList.remove('shattering');
        typedText.textContent = '';
        terminalBox?.classList.remove('crack');
        setTimeout(() => typeLoop(0), 380);
      }, 1050);
    }

    setTimeout(() => typeLoop(0), 3200);

    function animateCount(el, target, suffix = '', duration = 1200) {
      const startTime = performance.now();
      function update(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const value = Math.floor(progress * target);
        el.textContent = value + suffix;
        if (progress < 1) requestAnimationFrame(update);
        else el.textContent = target + suffix;
      }
      requestAnimationFrame(update);
    }

    const skillObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const fills = entry.target.querySelectorAll('.skill-fill');
          const counts = entry.target.querySelectorAll('.skill-percent');

          fills.forEach((fill, i) => {
            setTimeout(() => {
              fill.style.width = fill.dataset.progress + '%';
            }, i * 120);
          });

          counts.forEach((count, i) => {
            const target = parseInt(count.dataset.count || '0', 10);
            setTimeout(() => animateCount(count, target, '%', 1200), i * 120);
          });

          skillObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.25 });

    const skillsSection = document.getElementById('skills');
    if (skillsSection) skillObserver.observe(skillsSection);

    const tiltTargets = document.querySelectorAll('.card, .neo');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function tiltMove(e){
      if (reduced || window.innerWidth < 900) return;
      if (this.classList.contains('nav')) return;
      const rect = this.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const rx = ((y / rect.height) - 0.5) * -3.2;
      const ry = ((x / rect.width) - 0.5) * 3.2;
      this.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-2px)`;
    }
    function tiltReset(){
      this.style.transform = '';
    }
    tiltTargets.forEach(el => {
      el.addEventListener('mousemove', tiltMove);
      el.addEventListener('mouseleave', tiltReset);
    });
  </script>
</body>
</html>
