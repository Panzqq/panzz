        </button>

        <div class="nav-links menu-panel" id="navLinks">
          <a href="#landing">[ home ]</a>
          <a href="#about">[ about ]</a>
          <a href="#projects">[ projects ]</a>
          <a href="#skills">[ skills ]</a>
          <a href="#contact">[ contact ]</a>
        </div>
      </nav>
    </div>
  </div>

  <main>
    <section class="hero" id="landing">
      <div class="container">
        <div class="hero-main neo assemble assemble-up show">
          <div class="hero-noise"></div>

          <div class="hero-split">
            <div class="hero-left">
              <div class="hero-top">
                <div class="hero-avatar">
                  <img src="https://raw.githubusercontent.com/Panzqq/panzz/main/uploads/2026-03-20/RenV-22542.jpeg" alt="Foto profil Panpan">
                </div>
              </div>

              <h1>
                Hello, I'm
                <br>
                <span class="outline">Pan Pan! 👋</span>
                <br>
                <span class="accent">from Indonesia</span>
              </h1>

              <div class="hero-title-note">[ WhatsApp automation • API systems • web interfaces ]</div>

              <div class="hero-meta-line">
                <span class="code-chip black">@panpan</span>
              </div>

              <div class="hero-badges">
                <span class="code-chip yellow">Indonesia</span>
                <span class="code-chip green">Available for Projects</span>
                <span class="code-chip black">Online</span>
              </div>

              <p>
                A passionate developer from Indonesia who loves creating innovative digital solutions.
                I specialize in WhatsApp bot development and modern web applications, turning complex ideas
                into user-friendly experiences.
              </p>

              <div class="hero-actions">
                <a class="btn btn-green" href="https://wa.me/6285702107250?text=Halo%20Panpan%2C%20saya%20ingin%20kontak%20bot%20kamu." target="_blank">[ Contact Me ]</a>
                <a class="btn btn-yellow" href="#projects">&gt; view_projects()</a>
              </div>
            </div>
            </div>

            <div class="hero-right">
              <div class="typing-row" style="margin-top:8px;">
                <div class="terminal-box">
                  <div class="terminal-head">
                    <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                    <span>terminal / panpan.sh</span>
                  </div>
                  <div class="terminal-body">
                    <div class="terminal-line"><span class="prompt">panpan@dev:~$</span> <span id="typedText"></span><span class="cursor">|</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="ticker-wrap">
        <div class="ticker">
          <span>&gt; WhatsApp Bot</span>
          <span>[+] API Platform</span>
          <span>{ Modern Web App }</span>
          <span>&gt; Indonesia Developer</span>
          <span>[ client_ready ]</span>
          <span>{ innovation }</span>
          <span>&gt; WhatsApp Bot</span>
          <span>[+] API Platform</span>
          <span>{ Modern Web App }</span>
          <span>&gt; Indonesia Developer</span>
          <span>[ client_ready ]</span>
          <span>{ innovation }</span>
        </div>
      </div>
    </section>

    
    
<section class="section assemble assemble-up music-section">
  <div class="container">
    <div class="music-console neo">
      <div class="music-console-top">
        <div class="music-dots"><span></span><span></span><span></span></div>
        <span>music.console / now-playing</span>
      </div>

      <div class="music-console-body">
        <div class="music-meta">
          <span class="eyebrow" style="background:var(--pink);">[ background_music ]</span>
          <h3>Ambient tracks for the portfolio experience</h3>
          <p>Auto starts after loading finishes, loops continuously, and can be paused anytime from this console. Swipe or scroll sideways to pick a track.</p>
        </div>

        <div class="music-controls">
          <div class="music-status-line">
            <span class="code-chip black" id="musicStatusChip">status: ready</span>
            <span class="code-chip cyan" id="currentTrackChip">track: Love Me Not</span>
          </div>

          <div class="music-buttons">
<button class="btn btn-green" id="playMusicBtn" type="button">[ PLAY ]</button>
            <button class="btn btn-yellow" id="pauseMusicBtn" type="button">[ PAUSE ]</button>
            <button class="btn btn-white" id="nextTrackBtn" type="button">[ NEXT ]</button>
</div>

          <div class="music-progress-wrap">
            <div class="music-time">
              <span id="musicCurrentTime">0:00</span>
              <span id="musicDuration">0:00</span>
            </div>
            <div class="music-progress" id="musicProgress" aria-label="Music progress bar">
              <span id="musicProgressBar"></span>
            </div>
          </div>

          <div class="playlist-shell">
            
<div class="music-track-rail" id="musicTrackRail">
              <button class="track-card active" data-track-index="0" type="button">
                <div class="track-thumb">
                  <img src="https://raw.githubusercontent.com/Panzqq/panzz/main/uploads/2026-03-25/RenV-30356.jpeg" alt="Love Me Not cover">
                  <span class="track-overlay">track_01</span>
                </div>
                <div class="track-content">
                  <span class="track-mini">[ track_01 ]</span>
                  <strong>Love Me Not</strong>
                  <small>main theme • loop</small>
                </div>
              </button>

              <button class="track-card" data-track-index="1" type="button">
                <div class="track-thumb">
                  <img src="https://raw.githubusercontent.com/Panzqq/panzz/main/uploads/2026-03-25/RenV-30356.jpeg" alt="One Last Time cover">
                  <span class="track-overlay">track_02</span>
                </div>
                <div class="track-content">
                  <span class="track-mini">[ track_02 ]</span>
                  <strong>One Last Time</strong>
                  <small>side track • mellow</small>
                </div>
              </button>

              <button class="track-card" data-track-index="2" type="button">
                <div class="track-thumb">
                  <img src="https://raw.githubusercontent.com/Panzqq/panzz/main/uploads/2026-03-25/RenV-30356.jpeg" alt="Impossible cover">
                  <span class="track-overlay">track_03</span>
                </div>
                <div class="track-content">
                  <span class="track-mini">[ track_03 ]</span>
                  <strong>Impossible</strong>
                  <small>alt track • emotional</small>
                </div>
              </button>
            </div>

            <button class="playlist-arrow" id="playlistNext" type="button" aria-label="Scroll right">›</button>
          </div>

          <div class="music-visualizer" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
          </div>
        </div>
      </div>

      <audio id="bgMusic" preload="metadata" loop></audio>
    </div>
  </div>
</section>



    <section class="section assemble assemble-left" id="about">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow" style="background:var(--green);">&gt; about_panpan</span>
          <h2>Designing tools that make communication and workflow easier.</h2>
          <p>
            I build small but useful digital products focused on messaging, automation, and developer-friendly systems.
            My approach is simple: make the interface clear, keep the logic clean, and create something that is actually helpful in daily use.
          </p>
        </div>

        <div class="about-grid">
          <div class="info-box neo assemble assemble-up" data-delay="1" style="background:var(--yellow);">
            <h3>About Me</h3>
            <p>
              I’m Panpan, an Indonesia-based developer who enjoys building WhatsApp bots, lightweight API services,
              and web interfaces with a strong visual identity. I like turning complex ideas into tools that feel clean,
              useful, and easy to understand.
            </p>
          </div>

          <div class="info-box neo assemble assemble-right" data-delay="2" style="background:#fff;">
            <h3>What I Usually Work On</h3>
            <div class="list">
              <div>WhatsApp bots for support, orders, and communities</div>
              <div>REST APIs for integrations and developer tools</div>
              <div>Landing pages and dashboards for digital products</div>
              <div>Custom automation for repetitive workflows</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section config-section assemble assemble-up">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow" style="background:var(--cyan);">{ core_setup }</span>
          <h2>Core setup and service focus.</h2>
          <p>
            A quick look at the main identity and current direction behind this portfolio.
          </p>
        </div>

        <div class="code-window neo assemble assemble-pop" data-delay="1">
          <div class="window">
            <div class="window-head">
              <span>bot.config.js</span>
              <span>[ running ]</span>
            </div>
            <div class="code-body">
              <div><span class="k">export</span> <span class="k">default</span> <span class="f">definePanpan</span>({</div>
              <div>&nbsp;&nbsp;<span class="c">owner</span>: <span class="s">"Panpan"</span>,</div>
              <div>&nbsp;&nbsp;<span class="c">Service</span>: <span class="s">"WhatsApp Bot"</span>,</div>
              <div>&nbsp;&nbsp;<span class="c">Motivasion</span>: <span class="s">"Wi Wok De Tok"</span>,</div>
              <div>&nbsp;&nbsp;<span class="c">status</span>: <span class="s">"Online"</span></div>
              <div>});</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section assemble assemble-right" id="projects">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow" style="background:var(--yellow);">&gt; projects</span>
          <h2>Selected projects and active work.</h2>
          <p>
            A few examples of products and systems I’ve been building in the WhatsApp bot and API space.
          </p>
        </div>

        <div class="projects-grid">
          <div class="project neo assemble assemble-left" data-delay="1">
            <div class="project-thumb">
              <img src="https://raw.githubusercontent.com/Panzqq/panzz/main/uploads/2026-03-20/RenV-22542.jpeg" alt="Thumbnail Renvy WhatsApp Bot">
            </div>
            <div class="project-icon">🤖</div>
            <h3>Renvy WhatsApp Bot</h3>
            <p>
              Advanced WhatsApp bot with AI integration, automated responses, media handling, and group management.
              Supports multiple commands and custom features for business automation.
